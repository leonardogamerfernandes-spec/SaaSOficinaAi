# Backend Environment Configuration

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL for prod, SQLite for local dev)
# For local dev with SQLite:
# DATABASE_URL="file:./dev.db"
# For PostgreSQL (Docker/production):
DATABASE_URL="postgresql://oficinaai:oficinaai_secret@localhost:5432/oficinaai?schema=public"

# JWT Secret (change in production!)
JWT_SECRET="change-me-to-a-strong-random-secret"

# Google Gemini AI API Key (optional - mock responses used if empty)
GEMINI_API_KEY=""

# CORS allowed origin (frontend URL)
CORS_ORIGIN="http://localhost:3000"
