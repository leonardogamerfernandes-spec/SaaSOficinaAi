# OficinaAI Backend — Environment Variables
# Copy this file to .env and fill in the values

PORT=3001
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres?schema=public"

# JWT Secret (generate a strong random string with 64+ characters)
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET"

# Google Gemini API Key (for AI features)
GEMINI_API_KEY=""

# Frontend URL (for CORS)
CORS_ORIGIN="http://localhost:3000"

# Mercado Pago API (Get tokens from your developer account dashboard)
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-..."
MERCADO_PAGO_WEBHOOK_SECRET="your_webhook_secret"
